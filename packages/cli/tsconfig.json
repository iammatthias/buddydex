{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun-types"],
    "paths": {
      "@buddy/engine": ["../engine/src/index.ts"],
      "@buddy/engine/constants": ["../engine/src/constants.ts"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
